<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox is disabled so the app can write freely to user-chosen
         notes folders under ~/Documents and friends. Under the sandbox,
         macOS Tahoe denies writes through user-selected bookmarks with
         NSCocoaErrorDomain 513 / EPERM even though reads succeed.
         Re-enable and restore the read-write + app-scope-bookmark keys
         below if/when we ship to the App Store. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
